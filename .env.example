# ===========================================
# Configuration globale du serveur média
# ===========================================

# Chemins racine des médias
ROOT_MOVIES=/media/films
ROOT_TV=/media/series

# Radarr (Gestion des films)
RADARR_URL=http://radarr:7878/api/v3
RADARR_API_KEY=CHANGE_ME

# Sonarr (Gestion des séries)
SONARR_URL=http://sonarr:8989/api/v3
SONARR_API_KEY=CHANGE_ME

# Prowlarr (Indexeur)
PROWLARR_URL=http://prowlarr:9696/api/v1
PROWLARR_API_KEY=CHANGE_ME

# Transmission (Client torrent)
TRANSMISSION_URL=http://transmission:9091/transmission/rpc
TRANSMISSION_USER=
TRANSMISSION_PASS=

# Jellyfin (Serveur média)
JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=CHANGE_ME

# Serveur MCP (Model Context Protocol)
MCP_PORT=8080

# OAuth2 Proxy (Authentification)
# OAUTH2_PROXY_CLIENT_ID=
# OAUTH2_PROXY_CLIENT_SECRET=
# OAUTH2_PROXY_COOKIE_SECRET=
