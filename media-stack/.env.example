# --- Identité conteneurs ---
PUID=1000
PGID=1000
TZ=Europe/Paris

# --- Chemins de données ---
PROWLARR_CONFIG=/var/lib/prowlarr
SONARR_CONFIG=/var/lib/sonarr
RADARR_CONFIG=/var/lib/radarr
TRANSMISSION_CONFIG=/var/lib/transmission-daemon
MEDIA_MOVIES=/mnt/media/movies
MEDIA_TV=/mnt/media/series
MEDIA_DOWNLOADS=/mnt/media/downloads
MEDIA_WATCH=/mnt/media/watch
GLUETUN_DATA=/srv/docker/gluetun

# --- VPN (ProtonVPN via Gluetun / OpenVPN) ---
# Décommenter et configurer pour ProtonVPN
#VPN_SERVICE_PROVIDER=protonvpn
#OPENVPN_USER=YOUR_PROTONVPN_USERNAME
#OPENVPN_PASSWORD=YOUR_PROTONVPN_PASSWORD
#SERVER_COUNTRIES=Romania

# --- VPN (Mullvad via Gluetun / WireGuard) ---
# Décommenter et configurer pour Mullvad
VPN_SERVICE_PROVIDER=mullvad
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=YOUR_WIREGUARD_PRIVATE_KEY
WIREGUARD_ADDRESSES=10.x.x.x/32
SERVER_CITIES=Bucharest

# --- Domaine et certificats ---
MCP_DOMAIN=mcp.example.com
LE_EMAIL=admin@example.com

# --- Sécurité MCP ---
# Secret d'accès MCP (utilisé par media-mcp et envoyé à ChatGPT)
MCP_BEARER=CHANGE_ME_TO_SECURE_TOKEN
