OAUTH2_PROXY_PROVIDER=github
OAUTH2_PROXY_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
OAUTH2_PROXY_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET
OAUTH2_PROXY_COOKIE_SECRET=YOUR_COOKIE_SECRET  # générer avec: openssl rand -base64 32

OAUTH2_PROXY_SCOPE=read:org user:email

OAUTH2_PROXY_HTTP_ADDRESS=0.0.0.0:4180
OAUTH2_PROXY_EMAIL_DOMAINS=*
OAUTH2_PROXY_REDIRECT_URL=https://auth.example.com/oauth2/callback
OAUTH2_PROXY_WHITELIST_DOMAINS=.example.com

OAUTH2_PROXY_COOKIE_SECURE=true
OAUTH2_PROXY_COOKIE_SAMESITE=lax
OAUTH2_PROXY_COOKIE_PATH=/
OAUTH2_PROXY_COOKIE_NAME=_mcp_session
OAUTH2_PROXY_COOKIE_DOMAINS=.example.com

OAUTH2_PROXY_REVERSE_PROXY=true
OAUTH2_PROXY_SKIP_PROVIDER_BUTTON=true
OAUTH2_PROXY_SKIP_AUTH_ROUTES=^/health$

OAUTH2_PROXY_PASS_ACCESS_TOKEN=true
OAUTH2_PROXY_SET_XAUTHREQUEST=true
OAUTH2_PROXY_SET_AUTHORIZATION_HEADER=false

OAUTH2_PROXY_STANDARD_LOGGING=true
OAUTH2_PROXY_REQUEST_LOGGING=true
OAUTH2_PROXY_AUTH_LOGGING=true
